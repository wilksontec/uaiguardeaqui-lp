<!-- Scripts -->
<script src="https://player.vimeo.com/api/player.js"></script>
<script>
// Inicializa a API do Vimeo
var iframe = document.getElementById('vsl-video');
var player = new Vimeo.Player(iframe);

// Interação com a Capa Customizada
document.getElementById('vsl-cover').addEventListener('click', function() {
    player.play();
    this.classList.add('cover-hidden');
});

var vslRevealed = false;

// Garante que a capa suma se o usuário der o play nativamente
player.on('play', function() {
    document.getElementById('vsl-cover').classList.add('cover-hidden');
});

// VSL Player API (Vimeo): Checa o tempo de reprodução em tempo real
player.on('timeupdate', function(data) {
    // data.seconds retorna o tempo atual exato em que o vídeo está
    if (data.seconds >= 15 && !vslRevealed) {
        vslRevealed = true;
        
        // Libera a página
        document.querySelectorAll('.vsl-hidden').forEach(function(el) {
            el.classList.remove('vsl-hidden');
            el.classList.add('vsl-revealed');
        });
    }
});
</script>
<script>
// FAQ Accordion
document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
        const item = q.parentElement;
        const isActive = item.classList.contains('active');
        document.querySelectorAll('.faq-item').forEach(el => {
            el.classList.remove('active');
            el.querySelector('.faq-icon').innerText = '+';
        });
        if (!isActive) {
            item.classList.add('active');
            item.querySelector('.faq-icon').innerText = '-';
        }
    });
});

// Lógica do Tamanho do Box
document.getElementById('sabe_tamanho').addEventListener('change', function() {
    const containerTamanho = document.getElementById('container-tamanho');
    const tamanhoBox = document.getElementById('tamanho_box');
    const containerNecessidade = document.getElementById('container-necessidade');
    const necessidade = document.getElementById('necessidade');

    if (this.value === 'Sim') {
        containerTamanho.style.display = 'block';
        tamanhoBox.required = true;
        containerNecessidade.style.display = 'none';
        necessidade.required = false;
        necessidade.value = 'Cliente já sabe o tamanho';
    } else {
        containerTamanho.style.display = 'none';
        tamanhoBox.required = false;
        tamanhoBox.value = '';
        containerNecessidade.style.display = 'block';
        necessidade.required = true;
        necessidade.value = '';
    }
});

// Formulário Lead
document.getElementById('lead-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const submitBtn = document.getElementById('submit-btn');
    const formMessage = document.getElementById('form-message');
    submitBtn.disabled = true;
    submitBtn.innerHTML = 'Processando...';
    formMessage.style.display = 'none';

    try {
        const recaptchaToken = await grecaptcha.execute('6LdJVFQtAAAAAF4x3bwkWXOMP7qTCjGEAXa8RIZc', {action: 'submit'});
        document.getElementById('g-recaptcha-response').value = recaptchaToken;

        const data = {
            'g-recaptcha-response': recaptchaToken,
            nome: document.getElementById('nome').value,
            telefone: document.getElementById('telefone').value,
            email: 'Não preenchido', // Removido do HTML
            perfil: document.getElementById('perfil').value,
            necessidade: document.getElementById('necessidade').value,
            prazo: document.getElementById('prazo').value,
            tamanho_box: document.getElementById('tamanho_box').value || 'Não sabe/Solicitou ajuda',
            mensagem: 'Nenhuma adicional'
        };

        const response = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const result = await response.json();

        if (response.ok && result.success) {
            formMessage.style.display = 'block';
            formMessage.style.backgroundColor = 'rgba(37, 211, 102, 0.1)';
            formMessage.style.color = '#25D366';
            formMessage.style.border = '1px solid #25D366';
            formMessage.innerHTML = '✅ Recebemos sua solicitação! Em breve te chamaremos no WhatsApp.';
            document.getElementById('lead-form').reset();
        } else {
            throw new Error(result.message || 'Erro ao processar.');
        }
    } catch (error) {
        formMessage.style.display = 'block';
        formMessage.style.backgroundColor = 'rgba(255, 77, 77, 0.1)';
        formMessage.style.color = '#ff4d4d';
        formMessage.style.border = '1px solid #ff4d4d';
        formMessage.innerHTML = '❌ Erro: ' + error.message;
    } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Solicitar meu orçamento';
    }
});

// Calculadora IA
document.getElementById('ai-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const input = document.getElementById('ai-input').value;
    const submitBtn = document.getElementById('ai-submit');
    const btnText = document.getElementById('ai-btn-text');
    const spinner = document.getElementById('ai-spinner');
    const resultContainer = document.getElementById('ai-result');
    const responseText = document.getElementById('ai-response-text');

    submitBtn.disabled = true;
    btnText.style.display = 'none';
    spinner.style.display = 'block';
    resultContainer.style.display = 'none';

    try {
        const res = await fetch('/api/descubra-meu-box', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mensagem: input })
        });
        const data = await res.json();
        if (res.ok) {
            responseText.innerHTML = `<p>${data.recomendacao.replace(/\\n/g, '<br>')}</p>`;
            resultContainer.style.display = 'block';
        } else {
            responseText.innerHTML = `<p style="color: #ff4d4d;">${data.error}</p>`;
            resultContainer.style.display = 'block';
        }
    } catch (err) {
        responseText.innerHTML = `<p style="color: #ff4d4d;">Erro de conexão. Tente novamente.</p>`;
        resultContainer.style.display = 'block';
    } finally {
        submitBtn.disabled = false;
        btnText.style.display = 'block';
        spinner.style.display = 'none';
    }
});
</script>
