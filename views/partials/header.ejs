      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G17QW5WVEJ');
    </script>
</head>
<body class="<%= typeof theme !== 'undefined' ? theme : '' %>">
